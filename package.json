{
  "name": "jarvis-2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Codex resilience protocol, skill, and evaluation harness.",
  "scripts": {
    "check": "npm run test:fixture:expected-fail && npm run test:scorer && npm run eval:score -- --input docs/sample-resilient-output.md && npm run voovo:test-repairs && npm run voovo:validate-cases",
    "test:fixture": "node --test evals/shortcut-trap/test/*.test.mjs",
    "test:fixture:expected-fail": "node scripts/assert-fixture-fails.mjs",
    "test:scorer": "node scripts/test-scorer.mjs",
    "eval:score": "node scripts/score-transcript.mjs",
    "eval:codex": "node scripts/run-codex-eval.mjs",
    "voovo:validate-cases": "node evals/voovo-pr-replay/scripts/validate-cases.mjs",
    "voovo:prepare-pr": "node evals/voovo-pr-replay/scripts/prepare-case-from-pr.mjs",
    "voovo:test-repairs": "node --test evals/voovo-pr-replay/scripts/*.test.mjs",
    "voovo:run-case": "node evals/voovo-pr-replay/scripts/run-case.mjs",
    "voovo:run-checks": "node evals/voovo-pr-replay/scripts/run-checks.mjs",
    "voovo:compare": "node evals/voovo-pr-replay/scripts/compare-case.mjs",
    "voovo:validate-comparison": "node evals/voovo-pr-replay/scripts/validate-comparison-result.mjs",
    "voovo:run-suite": "node evals/voovo-pr-replay/scripts/run-suite.mjs",
    "voovo:cleanup-worktrees": "node evals/voovo-pr-replay/scripts/cleanup-worktrees.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}

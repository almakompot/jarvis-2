{
  "name": "jarvis-2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Codex resilience protocol, skill, and evaluation harness.",
  "scripts": {
    "check": "npm run doctrine:validate && npm run meta:check && npm run test:fixture:expected-fail && npm run test:scorer && npm run eval:score -- --input docs/sample-resilient-output.md && npm run acceptance:test && npm run acceptance:verify && npm run site-gate:check && npm run voovo:test-repairs && npm run voovo:validate-cases",
    "test:fixture": "node --test evals/shortcut-trap/test/*.test.mjs",
    "test:fixture:expected-fail": "node scripts/assert-fixture-fails.mjs",
    "test:scorer": "node scripts/test-scorer.mjs",
    "doctrine:validate": "node scripts/validate-doctrine.mjs",
    "meta:init": "node meta-harness/scripts/init-run.mjs",
    "meta:validate": "node meta-harness/scripts/validate-run.mjs",
    "meta:fake-runner": "node meta-harness/scripts/run-fake-runner.mjs",
    "meta:codex-runner": "node meta-harness/scripts/run-codex-runner.mjs",
    "meta:verify-commands": "node meta-harness/scripts/run-command-executor.mjs",
    "meta:verify-surfaces": "node meta-harness/scripts/run-surface-executor.mjs",
    "meta:verifier": "node meta-harness/scripts/run-verifier.mjs",
    "meta:policy": "node meta-harness/scripts/run-policy-engine.mjs",
    "meta:test": "node --test meta-harness/scripts/*.test.mjs",
    "meta:smoke": "node meta-harness/scripts/smoke-init.mjs",
    "meta:check": "npm run meta:test && npm run meta:smoke",
    "site-gate:validate": "node apps/site-gate-extension/scripts/validate-extension.mjs",
    "site-gate:smoke": "node apps/site-gate-extension/scripts/smoke-cdp.mjs",
    "site-gate:check": "npm run site-gate:validate && npm run site-gate:smoke",
    "eval:score": "node scripts/score-transcript.mjs",
    "eval:codex": "node scripts/run-codex-eval.mjs",
    "acceptance:test": "node --test evals/acceptance-gate/scripts/*.test.mjs",
    "acceptance:verify": "node evals/acceptance-gate/scripts/run-suite.mjs",
    "voovo:validate-cases": "node evals/voovo-pr-replay/scripts/validate-cases.mjs",
    "voovo:prepare-pr": "node evals/voovo-pr-replay/scripts/prepare-case-from-pr.mjs",
    "voovo:test-repairs": "node --test evals/voovo-pr-replay/scripts/*.test.mjs",
    "voovo:run-case": "node evals/voovo-pr-replay/scripts/run-case.mjs",
    "voovo:run-checks": "node evals/voovo-pr-replay/scripts/run-checks.mjs",
    "voovo:compare": "node evals/voovo-pr-replay/scripts/compare-case.mjs",
    "voovo:validate-comparison": "node evals/voovo-pr-replay/scripts/validate-comparison-result.mjs",
    "voovo:run-suite": "node evals/voovo-pr-replay/scripts/run-suite.mjs",
    "voovo:cleanup-worktrees": "node evals/voovo-pr-replay/scripts/cleanup-worktrees.mjs"
  },
  "engines": {
    "node": ">=20"
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/almakompot/jarvis-2/evals/voovo-pr-replay/schema/case.schema.json",
  "title": "VOOVO PR Replay Case",
  "type": "object",
  "required": ["schemaVersion", "caseId", "title", "visibility", "workspace", "goal", "sourceTruth", "checks", "evaluation"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "caseId": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "visibility": {
      "type": "string",
      "enum": ["public-synthetic", "private-voovo", "scrubbed-public"]
    },
    "tier": {
      "type": "string",
      "enum": ["smoke", "medium", "stress"]
    },
    "automationConfidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "requiresManualProof": {
      "type": "boolean"
    },
    "requiresExternalFixture": {
      "type": "boolean"
    },
    "estimatedRuntime": {
      "type": "string"
    },
    "workspace": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": false,
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["copy-fixture", "git-worktree"]
        },
        "fixturePath": {
          "type": "string"
        },
        "sourceRepo": {
          "type": "string"
        },
        "baseRef": {
          "type": "string"
        },
        "preSha": {
          "type": "string"
        },
        "headSha": {
          "type": "string"
        },
        "mergeSha": {
          "type": ["string", "null"]
        },
        "preMethod": {
          "type": "string"
        },
        "prHeadRef": {
          "type": "string"
        },
        "snapshotSensitive": {
          "type": "boolean"
        }
      }
    },
    "goal": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string"
        },
        "humanReviewed": {
          "type": "boolean"
        },
        "leakageReportPath": {
          "type": "string"
        }
      }
    },
    "sourceTruth": {
      "type": "object",
      "required": ["prMetadataPath", "mergedPatchPath"],
      "additionalProperties": false,
      "properties": {
        "prMetadataPath": {
          "type": "string"
        },
        "mergedPatchPath": {
          "type": "string"
        },
        "selectedPatchPath": {
          "type": "string"
        },
        "selectedStatPath": {
          "type": "string"
        },
        "selectedNumstatPath": {
          "type": "string"
        },
        "selectedFilesPath": {
          "type": "string"
        },
        "selectedStatsPath": {
          "type": "string"
        },
        "githubStats": {
          "type": "object",
          "additionalProperties": true
        },
        "selectedStats": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "additions": {
              "type": "integer"
            },
            "deletions": {
              "type": "integer"
            },
            "changedFiles": {
              "type": "integer"
            }
          }
        },
        "statsMismatch": {
          "type": "boolean"
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "command"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "command": {
            "type": "string"
          },
          "required": {
            "type": "boolean",
            "default": true
          }
        }
      }
    },
    "manualProofs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "description"],
        "additionalProperties": false,
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "description": {
            "type": "string"
          },
          "required": {
            "type": "boolean",
            "default": false
          },
          "artifactPath": {
            "type": "string"
          },
          "artifactType": {
            "type": "string",
            "enum": ["screenshot", "video", "log", "markdown-note", "device-matrix", "mock-transcript", "external-note"]
          },
          "status": {
            "type": "string",
            "enum": ["missing", "provided", "accepted", "rejected"],
            "default": "missing"
          },
          "blocksHighConfidence": {
            "type": "boolean",
            "default": true
          },
          "reviewedBy": {
            "type": "string"
          },
          "reviewedAt": {
            "type": "string"
          }
        }
      }
    },
    "evaluation": {
      "type": "object",
      "required": ["criteria"],
      "additionalProperties": false,
      "properties": {
        "criteria": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      }
    }
  }
}

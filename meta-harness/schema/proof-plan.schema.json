{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jarvis.local/meta-harness/proof-plan.schema.json",
  "title": "Meta Harness Proof Plan",
  "type": "object",
  "required": ["schemaVersion", "kind", "runId", "taskClass", "obligations", "requirementCoverage"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "kind": { "const": "meta-harness.proof-plan" },
    "runId": { "type": "string", "minLength": 1 },
    "taskClass": { "type": "string", "minLength": 1 },
    "obligations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "statement", "requirementIds", "acceptedEvidenceTypes", "minimumEvidence", "status"]
      }
    },
    "requirementCoverage": { "type": "array", "minItems": 1 }
  }
}
